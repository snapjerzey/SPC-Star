@baseUrl = http://localhost:5000

### Health
GET {{baseUrl}}/health

### Login as demo operator
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "userName": "operator1",
  "password": "operator1"
}

### Import setup CSV
POST {{baseUrl}}/setup/import-csv
Content-Type: application/json

{
  "csv": "PartNum,PartDescription,ProcessCode,ProcessDescription,OperationSeq,CharacteristicName,CharacteristicType,Nominal,LSL,USL,UnitOfMeasure,SampleSize,FrequencyType,FrequencyValue,FrequencyUnit,AlertRuleSet,IsRequiredForCOA\nP200,Demo part,MOLD,Molding,10,Diameter,Variable,5.0,4.5,5.5,mm,1,Time,30,Minutes,WesternElectric,true"
}

### Add part-specific job data field
POST {{baseUrl}}/setup/job-data-fields
Content-Type: application/json

{
  "partNum": "P100",
  "inspectionPhase": "In Process",
  "fieldName": "Example Tag",
  "isRequired": true,
  "displayOrder": 0
}

### Enter inspection measurement
POST {{baseUrl}}/inspections/measurements
Content-Type: application/json

{
  "jobNum": "J100",
  "partNum": "P100",
  "processCode": "MOLD",
  "operationSeq": 10,
  "resourceId": "PRESS1",
  "characteristicName": "Diameter",
  "value": 5.1,
  "timestamp": "2026-05-01T12:00:00Z",
  "operatorUserId": "operator1",
  "deviceId": "tablet-press1",
  "clientRecordId": "measurement-001",
  "submittedAt": "2026-05-01T12:01:00Z"
}

### Record material lot change
POST {{baseUrl}}/material-changes
Content-Type: application/json

{
  "jobNum": "J100",
  "partNum": "P100",
  "materialPartNum": "RESIN-A",
  "oldLotNum": "LOT1",
  "newLotNum": "LOT2",
  "quantityLoaded": 500,
  "resourceId": "PRESS1",
  "operatorUserId": "operator1",
  "timestamp": "2026-05-01T12:10:00Z",
  "reason": "Loaded next material lot",
  "deviceId": "tablet-press1",
  "clientRecordId": "material-001",
  "submittedAt": "2026-05-01T12:11:00Z"
}

### List job notes
GET {{baseUrl}}/jobs/J100/notes

### Save persistent job tags
POST {{baseUrl}}/jobs/J100/tags
Content-Type: application/json

{
  "partNum": "P100",
  "resourceId": "PRESS1",
  "operatorUserId": "operator1",
  "tags": {
    "Example Tag": "Example Value"
  },
  "updatedAt": "2026-05-01T12:18:00Z"
}

### List job tags
GET {{baseUrl}}/jobs/J100/tags

### Add job note
POST {{baseUrl}}/jobs/J100/notes
Content-Type: application/json

{
  "jobNum": "J100",
  "partNum": "P100",
  "resourceId": "PRESS1",
  "operatorUserId": "operator1",
  "noteText": "Observed flash on cavity side. Line tech adjusted clamp settings.",
  "timestamp": "2026-05-01T12:20:00Z"
}

### Sync queued offline tablet changes
POST {{baseUrl}}/sync/offline-changes
Content-Type: application/json

{
  "measurements": [
    {
      "jobNum": "J100",
      "partNum": "P100",
      "processCode": "MOLD",
      "operationSeq": 10,
      "resourceId": "PRESS1",
      "characteristicName": "Diameter",
      "value": 5.1,
      "timestamp": "2026-05-01T12:00:00Z",
      "operatorUserId": "operator1",
      "deviceId": "tablet-press1",
      "clientRecordId": "measurement-001",
      "submittedAt": "2026-05-01T12:01:00Z"
    }
  ],
  "materialChanges": [],
  "alertOverrides": []
}

### Evaluate inspection frequency
POST {{baseUrl}}/inspection-frequency/evaluate
Content-Type: application/json

{
  "jobNum": "J100",
  "partNum": "P100",
  "processCode": "MOLD",
  "operationSeq": 10,
  "characteristicName": "Diameter",
  "resourceId": "PRESS1",
  "now": "2026-05-01T12:45:00Z",
  "currentQuantity": null,
  "quantityAtLastInspection": null,
  "events": []
}

### Tablet setup snapshot for offline cache
GET {{baseUrl}}/sync/setup-snapshot

### Tablet work context
GET {{baseUrl}}/work-context?jobNum=J100&partNum=P100&processCode=MOLD&operationSeq=10&resourceId=PRESS1&characteristicName=Diameter

### Chart data
POST {{baseUrl}}/charts/data
Content-Type: application/json

{
  "chartType": "IndividualsMovingRange",
  "jobNum": "J100",
  "partNum": "P100",
  "resourceId": "PRESS1",
  "characteristicName": "Diameter",
  "from": null,
  "to": null
}

### QA summary CSV
POST {{baseUrl}}/qa/summary.csv
Content-Type: application/json

{
  "partNums": ["P100"],
  "jobNums": ["J100"],
  "characteristicNames": ["Diameter"],
  "from": null,
  "to": null
}

### Override alert lock
POST {{baseUrl}}/alerts/00000000-0000-0000-0000-000000000000/override
Content-Type: application/json

{
  "overrideUserName": "qa1",
  "overridePassword": "qa1",
  "causeText": "Tool wear",
  "solutionText": "Changed tool and restarted inspection",
  "whyStandardProcessWasBypassed": null,
  "unlockedAt": "2026-05-01T12:30:00Z",
  "deviceId": "tablet-qa1",
  "clientRecordId": "override-001",
  "submittedAt": "2026-05-01T12:31:00Z"
}

### Export raw inspection data CSV
POST {{baseUrl}}/exports/inspection-data.csv
Content-Type: application/json

{
  "partNums": ["P100"],
  "jobNums": ["J100"],
  "resourceIds": ["PRESS1"],
  "characteristicNames": ["Diameter"],
  "from": null,
  "to": null
}
